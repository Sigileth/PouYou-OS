---
# yaml-language-server: $schema=https://schema.blue-build.org/recipe-v1.json
# image will be published to ghcr.io/<user>/<name>
name: pouyou-os
# description will be included in the image's metadata
description: This is my personal OS image.

# the base image to build on top of (FROM) and the version tag to use
base-image: ghcr.io/ublue-os/aurora-main
image-version: 43 # latest is also supported if you want new updates ASAP

# module configuration, executed in order
# you can include multiple instances of the same module
modules:
  - type: os-release
    properties:
      ID_LIKE: fedora
      ID: pouyou-os
      NAME: PouYou-OS
      PRETTY_NAME: PouYou-OS
      DEFAULT_HOSTNAME: PouYou-OS
      HOME_URL: https://github.com/Sigileth/PouYou-OS
      
  - type: files
    files:
      - source: system
        destination: / # copies files/system/* (* means everything inside it) into your image's root folder /

  - type: files
    files:
      - source: pouyou
        destination: / # copies files/pouyou/* (* means everything inside it) into your image's root folder /

  - type: dnf
    repos:
      nonfree: negativo17
    install:
      packages:
        - repo: updates  #pulling from updates to get latest version, when moving to 44 change back to fedora. 
          packages:
            - openrgb
        - fastfetch
        - gwenview
        - mangohud
        - okular
        - hidapi  #dependency for openrgb
        - steam
    remove:
      packages:
        # example: removing firefox
        # "firefox" is the main package, "firefox-langpacks" is a dependency
        #- fcitx5
        #- fcitx5-libs
        - firefox
        - firefox-langpacks # also remove firefox dependency (not required for all packages, this is a special case)
        - firewall-config
        - htop
        - kcharselect
        - kde-connect
        - kdebugsettings
        - krfb
        - plasma-discover
        - plasma-drkonqi
        - plasma-welcome
        - nvtop
        - vim-common
        - vim-data
        - vim-enhanced
        - vim-filesystem
        - vim-minimal
        - xxd
    group-install:
      with-optional: true
      packages:
        - virtualization

  - type: script
    snippets:
      - "plymouth-set-default-theme text"
        
  - type: systemd
    system:
      enabled:
        - libvirtd.service
        
  - type: default-flatpaks
    configurations:
      - notify: true # Send notification after install/uninstall is finished (true/false)
        scope: system
        # If no repo information is specified, Flathub will be used by default
        install: # system flatpaks we want all users to have and not remove
          - eu.betterbird.Betterbird
          - com.usebottles.bottles
          - io.gitlab.guillermop.Counters
          - cafe.avery.Delfin
          - com.github.wwmm.easyeffects
          - org.dupot.easyflatpak
          - io.github.Faugus.faugus-launcher
          - com.github.tchx84.Flatseal
          - fr.handbrake.ghb
          - com.heroicgameslauncher.hgl
          - org.kde.kcalc
          - org.kde.kmahjongg
          - org.kde.kronometer
          - org.libreoffice.LibreOffice
          - io.gitlab.librewolf-community
          - io.github.radiolamp.mangojuice
          - com.github.AmatCoder.mednaffe
          - org.openmw.OpenMW
          - io.github.berarma.Oversteer
          - net.pcsx2.PCSX2
          - org.ppsspp.PPSSPP
          - com.system76.Popsicle
          - com.vysp3r.ProtonPlus
          - com.github.Matoking.protontricks
          - net.rpcs3.RPCS3
          - io.github.mfat.sshpilot
          - org.strawberrymusicplayer.strawberry
          - org.videolan.VLC
          - dev.vencord.Vesktop
          - com.vivaldi.Vivaldi
          - io.github.flattool.Warehouse
      - scope: user # Also add Flathub user repo, but no user packages

  - type: initramfs    

  - type: signing # this sets up the proper policy & signing files for signed images to work fully
